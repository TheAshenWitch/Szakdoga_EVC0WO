<Window
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Szakdoga"
        xmlns:loc="clr-namespace:Szakdoga"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes" x:Class="Szakdoga.SettingsWindow"
        mc:Ignorable="d"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterScreen"
        Title="Settings" Height="450" Width="800" Background="#FF9C9C9C">

    <Window.Resources>
        <ObjectDataProvider x:Key="Loc" 
                    ObjectType="{x:Type loc:LocalizationManager}" 
                    MethodName="get_Instance"/>

        <Style x:Key="InfoIconStyle" TargetType="{x:Type Border}">
            <Setter Property="Width" Value="20"/>
            <Setter Property="Height" Value="20"/>
            <Setter Property="Background" Value="#2196F3"/>
            <Setter Property="CornerRadius" Value="10"/>
        </Style>
    </Window.Resources>

    <Grid DataContext="{StaticResource Loc}">
        <TextBox x:Name="SheetWidth" HorizontalAlignment="Left" Margin="40,43,0,0" TextWrapping="Wrap" VerticalAlignment="Top" Width="84" Height="28" ToolTip="mm" FontSize="18"/>
        <TextBox x:Name="SheetHeight" HorizontalAlignment="Left" Margin="226,43,0,0" TextWrapping="Wrap" VerticalAlignment="Top" Width="84" Height="28" ToolTip="mm" FontSize="18"/>
        <TextBox x:Name="BladeThickness" HorizontalAlignment="Left" Margin="40,114,0,0" TextWrapping="Wrap" VerticalAlignment="Top" Width="84" Height="28" ToolTip="mm" FontSize="18"/>
        <TextBox x:Name="SheetPadding" HorizontalAlignment="Left" Margin="226,114,0,0" TextWrapping="Wrap" VerticalAlignment="Top" Width="84" Height="28" ToolTip="mm" FontSize="18"/>
        <TextBox x:Name="SheetPrice" HorizontalAlignment="Left" Margin="40,187,0,0" TextWrapping="Wrap" VerticalAlignment="Top" Width="84" Height="28" ToolTip="mm" FontSize="18"/>
        <TextBox x:Name="EdgeSealingPrice" HorizontalAlignment="Left" Margin="226,187,0,0" TextWrapping="Wrap" VerticalAlignment="Top" Width="84" Height="28" ToolTip="mm" FontSize="18"/>
        <TextBox x:Name="SheetColor" HorizontalAlignment="Left" Margin="40,256,0,0" TextWrapping="Wrap" VerticalAlignment="Top" Width="84" Height="28" ToolTip="mm" FontSize="18"/>
        <TextBox x:Name="SheetManufacturer" HorizontalAlignment="Left" Margin="226,256,0,0" TextWrapping="Wrap" VerticalAlignment="Top" Width="84" Height="28" ToolTip="mm" FontSize="18"/>
        <Label Content="{Binding [SettingsWidthLabel]}" HorizontalAlignment="Left" Margin="10,8,0,0" VerticalAlignment="Top" Height="35" Width="143" FontSize="18" HorizontalContentAlignment="Center"/>
        <Label Content="{Binding [SettingsHeightLabel]}" HorizontalAlignment="Left" Margin="191,8,0,0" VerticalAlignment="Top" Height="35" Width="155" FontSize="18" HorizontalContentAlignment="Center"/>
        <Label Content="{Binding [SettingsBladeThicknessLabel]}" HorizontalAlignment="Left" Margin="10,79,0,0" VerticalAlignment="Top" Height="35" Width="143" FontSize="18" HorizontalContentAlignment="Center"/>
        <Label Content="{Binding [SettingsSheetPaddingLabel]}" HorizontalAlignment="Left" Margin="191,79,0,0" VerticalAlignment="Top" Height="35" Width="155" FontSize="18" HorizontalContentAlignment="Center"/>
        <Label Content="{Binding [SettingsSheetCostLabel]}" HorizontalAlignment="Left" Margin="10,152,0,0" VerticalAlignment="Top" Height="35" Width="143" FontSize="18" HorizontalContentAlignment="Center"/>
        <Label Content="{Binding [SettingsEdgeSealingCostLabel]}" HorizontalAlignment="Left" Margin="179,152,0,0" VerticalAlignment="Top" Height="35" Width="179" FontSize="18" HorizontalContentAlignment="Center"/>
        <Label Content="{Binding [SettingsSheetColor]}" HorizontalAlignment="Left" Margin="10,221,0,0" VerticalAlignment="Top" Height="35" Width="143" FontSize="18" HorizontalContentAlignment="Center"/>
        <Label Content="{Binding [SettingsSheetManufacturerLabel]}" HorizontalAlignment="Left" Margin="179,217,0,0" VerticalAlignment="Top" Height="35" Width="179" FontSize="18" HorizontalContentAlignment="Center"/>
        <Label Content="Language / Nyelv" HorizontalAlignment="Right" Margin="0, 5, 5, 0" VerticalAlignment="Top" Height="35" Width="155" FontSize="18" HorizontalContentAlignment="Center"/>
        <ComboBox x:Name="Lang" Width="56" Height="33" SelectedIndex="0" Margin="0,45,50,0" VerticalAlignment="Top" HorizontalAlignment="Right" FontSize="18">
            <ComboBoxItem Content="HU" Tag="hu-HU"/>
            <ComboBoxItem Content="EN" Tag="en-EN"/>
        </ComboBox>
        <Button Content="{Binding [ApplyButton]}" HorizontalAlignment="Left" Margin="40,0,0,30" VerticalAlignment="Bottom" Height="52" Width="143" Click="Apply_Click"/>

        <Border Style="{StaticResource InfoIconStyle}"
        HorizontalAlignment="Left" VerticalAlignment="Top" Margin="5,5,0,0"
        ToolTip="{Binding [SettingsTooltipText]}">
            <TextBlock Text="i" Foreground="White" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center"/>
        </Border>
    </Grid>
</Window>
