<Window x:Class="Szakdoga.ProjectExplorer"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Szakdoga"
        xmlns:loc="clr-namespace:Szakdoga"
        mc:Ignorable="d"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterScreen"
        Title="ProjectExplorer" Height="600" Width="1200">
    <Window.Resources>
        <local:EnumToBooleanConverter x:Key="EnumToBoolConverter"/>
        <ObjectDataProvider x:Key="Loc" 
                        ObjectType="{x:Type loc:LocalizationManager}" 
                        MethodName="get_Instance"/>

    </Window.Resources>
    <Grid Width="1180" Height="580" DataContext="{StaticResource Loc}">
        <ListBox Name="OrderListView" Margin="10,10,685,70" Height="500" MouseDoubleClick="OpenOrder" ScrollViewer.HorizontalScrollBarVisibility="Hidden" AlternationCount="2">
            <ListBox.ItemContainerStyle>

                <Style TargetType="ListBoxItem">
                    <Setter Property="Background" Value="White"/>

                    <Style.Triggers>
                        <Trigger Property="ItemsControl.AlternationIndex" Value="1">
                            <Setter Property="Background" Value="#F0F0F0"/>
                        </Trigger>
                    </Style.Triggers>
                </Style>
            </ListBox.ItemContainerStyle>

            <ListBox.ItemTemplate>
                <DataTemplate>
                    <Grid Margin="0,2" Height="25">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="180" />
                            <ColumnDefinition Width="180" />
                            <ColumnDefinition Width="100" />
                        </Grid.ColumnDefinitions>
                        <!-- 1. oszlop – Cím -->
                        <TextBlock Grid.Column="0"
                                   Text="{Binding Title}"
                                   FontWeight="Bold"
                                   FontSize="14"
                                   VerticalAlignment="Center"
                                   Margin="5,0" />

                        <!-- 2. oszlop – Megrendelő -->
                        <TextBlock Grid.Column="1"
                                   Text="{Binding Customer.Name}"
                                   FontWeight="SemiBold"
                                   FontSize="13"
                                   VerticalAlignment="Center"
                                   Margin="5,0" />

                        <!-- 4. oszlop – Dátum -->
                        <TextBlock Grid.Column="3"
                                   Text="{Binding CreatedAt, StringFormat={}{0:yyyy.MM.dd}}"
                                   Foreground="Gray"
                                   FontSize="12"
                                   VerticalAlignment="Center"
                                   Margin="10,0,0,0" />
                    </Grid>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>
        <Button Content="{Binding [AddNewOrderLabel]}" Margin="500,10,550,490" Click="AddNewOrder" HorizontalContentAlignment="Center" Width="130" Height="80" FontSize="20"/>
        <Button Content="{Binding [AddNewCustomerLabel]}" Margin="500,95,550,405" Click="AddNewCustomer" HorizontalContentAlignment="Center" Width="130" Height="80" FontSize="20"/>
        <Button Content="{Binding [AddNewSheetLabel]}" Name="AddNewSheetButton" Margin="500,180,550,322" Click="AddNewSheet" Width="130" FontSize="20" HorizontalContentAlignment="Center"/>
        <Button Content="{Binding [ModifyOderLabel]}" Margin="635,10,415,490" Click="UpdateOrder" HorizontalContentAlignment="Center" Width="130" Height="80" FontSize="20"/>
        <Button Content="{Binding [ModifyCustomerLabel]}" Margin="635,95,415,405" Click="UpdateCustomer" HorizontalContentAlignment="Center" Width="130" Height="80" FontSize="20"/>
        <Button Content="{Binding [ModifySheetLabel]}" Margin="635,180,415,322" Click="UpdateSheet" HorizontalContentAlignment="Center" Width="130" FontSize="20"/>
        <Button Content="{Binding [DeleteOrderLabel]}" Margin="770,10,280,490" Click="DeleteOrder" HorizontalContentAlignment="Center" Width="130" Height="80" FontSize="20"/>
        <Button Content="{Binding [DeleteCustomerLabel]}" Margin="770,95,280,405" Click="DeleteCustomer" HorizontalContentAlignment="Center" Width="130" Height="80" FontSize="20"/>
        <Button Content="{Binding [DeleteSheetLabel]}" Margin="770,180,280,322" Click="DeleteSheet" HorizontalContentAlignment="Center" Width="130" FontSize="20"/>
        <Button Content="{Binding [ContinueWithoutOrder]}" Margin="0,10,10,0" Click="MainScreen" Width="130" HorizontalAlignment="Right" Height="80" VerticalAlignment="Top" FontSize="18"/>
        <Button Content="{Binding [SettingsButton]}" Margin="0,95,10,0" Click="OpenSettings" Width="130" Height="80" HorizontalAlignment="Right" VerticalAlignment="Top" FontSize="20"/>

    </Grid>
</Window>
