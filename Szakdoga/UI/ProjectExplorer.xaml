<Window x:Class="Szakdoga.ProjectExplorer"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Szakdoga"
        xmlns:loc="clr-namespace:Szakdoga"
        mc:Ignorable="d"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterScreen"
        Title="ProjectExplorer" Height="600" Width="1200">
    <Window.Resources>
        <local:EnumToBooleanConverter x:Key="EnumToBoolConverter"/>
        <ObjectDataProvider x:Key="Loc" 
                        ObjectType="{x:Type loc:LocalizationManager}" 
                        MethodName="get_Instance"/>

    </Window.Resources>
    <Grid Width="1180" Height="580" DataContext="{StaticResource Loc}">
        <ListBox Height="520" Width="520" Name="OrderListView" Margin="10,30,0,0" MouseDoubleClick="OpenOrder" HorizontalAlignment="Left" VerticalAlignment="Top" ScrollViewer.HorizontalScrollBarVisibility="Hidden" AlternationCount="2" d:ItemsSource="{d:SampleData ItemCount=5}">
            <ListBox.ItemContainerStyle>

                <Style TargetType="ListBoxItem">
                    <Setter Property="Background" Value="White"/>

                    <Style.Triggers>
                        <Trigger Property="ItemsControl.AlternationIndex" Value="1">
                            <Setter Property="Background" Value="#F0F0F0"/>
                        </Trigger>
                    </Style.Triggers>
                </Style>
            </ListBox.ItemContainerStyle>

            <ListBox.ItemTemplate>
                <DataTemplate>
                    <Grid Margin="0,2" Height="25">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="170" />
                            <ColumnDefinition Width="120" />
                            <ColumnDefinition Width="120" />
                            <ColumnDefinition Width="70" />
                        </Grid.ColumnDefinitions>
                        <!-- 1. oszlop – Cím -->
                        <TextBlock Grid.Column="0"
                                   Text="{Binding Title}"
                                   FontWeight="Bold"
                                   FontSize="14"
                                   VerticalAlignment="Center"
                                   Margin="5, 0, 10, 0" />

                        <!-- 2. oszlop – Megrendelő -->
                        <TextBlock Grid.Column="1"
                                   Text="{Binding Customer.Name}"
                                   FontWeight="SemiBold"
                                   FontSize="13"
                                   VerticalAlignment="Center"
                                   Margin="5, 0, 10, 0" />
                        
                        <TextBlock Grid.Column="2"
                                   Text="{Binding Sheet.Name}"
                                   FontWeight="SemiBold"
                                   FontSize="13"
                                   VerticalAlignment="Center"
                                   Margin="5, 0, 10, 0" />

                        <!-- 4. oszlop – Dátum -->
                        <TextBlock Grid.Column="3"
                                   Text="{Binding CreatedAt, StringFormat={}{0:yyyy.MM.dd}}"
                                   Foreground="Gray"
                                   FontSize="12"
                                   VerticalAlignment="Center"
                                   Margin="5, 0, 0, 0" />
                    </Grid>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>
        <Label Content="{Binding [PEOrderTitle]}" Margin="17, 0, 0, 0" HorizontalAlignment="Left" VerticalAlignment="Top" FontSize="15" FontWeight="SemiBold"/>
        <Label Content="{Binding [PECustomerName]}" Margin="187, 0, 0, 0" HorizontalAlignment="Left" VerticalAlignment="Top" FontSize="15"/>
        <Label Content="{Binding [PESheetName]}" Margin="307, 0, 0, 0" HorizontalAlignment="Left" VerticalAlignment="Top" FontSize="15"/>
        <Label Content="{Binding [PEDate]}" Margin="427, 0, 0, 0" HorizontalAlignment="Left" VerticalAlignment="Top" FontSize="15" FontWeight="Light" />

        <Button Content="{Binding [AddNewOrderLabel]}" Margin="540, 30, 0, 0" Click="AddNewOrder" HorizontalContentAlignment="Center" Width="130" Height="80" HorizontalAlignment="Left" VerticalAlignment="Top" FontSize="20"/>
        <Button Content="{Binding [AddNewCustomerLabel]}" Margin="540, 115, 0, 0" Click="AddNewCustomer" HorizontalContentAlignment="Center" Width="130" Height="80" HorizontalAlignment="Left" VerticalAlignment="Top" FontSize="20"/>
        <Button Content="{Binding [AddNewSheetLabel]}" Margin="540, 200, 0, 0" Click="AddNewSheet" HorizontalContentAlignment="Center" Width="130" Height="80" HorizontalAlignment="Left" VerticalAlignment="Top" FontSize="20"  Name="AddNewSheetButton"/>
        <Button Content="{Binding [ModifyOderLabel]}" Margin="675, 30, 0, 0" Click="UpdateOrder" HorizontalContentAlignment="Center" Width="130" Height="80" HorizontalAlignment="Left" VerticalAlignment="Top" FontSize="20" Name="ModifyOrderButon"/>
        <Button Content="{Binding [ModifyCustomerLabel]}" Margin="675, 115, 0, 0" Click="UpdateCustomer" HorizontalContentAlignment="Center" Width="130" Height="80" HorizontalAlignment="Left" VerticalAlignment="Top" FontSize="20"/>
        <Button Content="{Binding [ModifySheetLabel]}" Margin="675, 200, 0, 0" Click="UpdateSheet" HorizontalContentAlignment="Center" Width="130" Height="80" HorizontalAlignment="Left" VerticalAlignment="Top" FontSize="20"/>
        <Button Content="{Binding [DeleteOrderLabel]}" Margin="810, 30, 0, 0" Click="DeleteOrder" HorizontalContentAlignment="Center" Width="130" Height="80" HorizontalAlignment="Left" VerticalAlignment="Top" FontSize="20" Name="DeleteOrderButton"/>
        <Button Content="{Binding [DeleteCustomerLabel]}" Margin="810, 115, 0, 0" Click="DeleteCustomer" HorizontalContentAlignment="Center" Width="130" Height="80" HorizontalAlignment="Left" VerticalAlignment="Top" FontSize="20"/>
        <Button Content="{Binding [DeleteSheetLabel]}" Margin="810, 200, 0, 0" Click="DeleteSheet" HorizontalContentAlignment="Center" Width="130" Height="80" HorizontalAlignment="Left" VerticalAlignment="Top" FontSize="20"/>
        <Button Content="{Binding [ContinueWithoutOrder]}" Margin="0, 30, 10, 0" Click="MainScreen" HorizontalContentAlignment="Center" Width="130" Height="80" HorizontalAlignment="Right" VerticalAlignment="Top" FontSize="18"/>
        <Button Content="{Binding [SettingsButton]}" Margin="0, 115, 10, 0" Click="OpenSettings" HorizontalContentAlignment="Center" Width="130" Height="80" HorizontalAlignment="Right" VerticalAlignment="Top" FontSize="20"/>

        <Button Content="{Binding [ManageInventoryButton]}" Margin="540, 0, 0, 30" Click="OpenInventoryManager" HorizontalContentAlignment="Center" Width="130" Height="80"  HorizontalAlignment="Left" VerticalAlignment="Bottom" FontSize="20"/>
    </Grid>
</Window>
